# Read-only config example: only the public hostname is required to serve images from R2.
# No upload credentials are needed since images are already hosted in R2.

NEXT_PUBLIC_R2_PUBLIC_HOSTNAME=e756f4804c78d3eae73a35b2afee4fe8.r2.cloudflarestorage.com

# Read-only config example: only the public hostname and bucket name are required to serve images from R2.
# No upload credentials are needed since images are already hosted in R2.

NEXT_PUBLIC_R2_PUBLIC_HOSTNAME=assets.keydeon.com
NEXT_PUBLIC_R2_BUCKET_NAME=keydeon

# If you later need to upload via scripts, add R2_ACCESS_KEY_ID and R2_SECRET_ACCESS_KEY to a local-only file (do NOT commit secrets).
